{
  "name": "recepten-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:rules": "npx --yes firebase-tools@14.24.2 emulators:exec --only firestore \"vitest run tests/firestore-rules.emulator.test.ts\" --project recepten-rules-test",
    "verify:backup": "node scripts/verify-backup-freshness.mjs",
    "deploy:safe": "npm test && npm run test:rules && npm run lint && npm run build && npm run verify:backup && npx --yes firebase-tools@14.24.2 deploy --only apphosting,firestore:rules --project recepten-app-87beb",
    "deploy": "npx --yes firebase-tools@14.24.2 deploy --only apphosting --project recepten-app-87beb"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "date-fns": "^4.1.0",
    "firebase": "^11.0.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fake-indexeddb": "^6.2.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
