{
  "name": "recepten-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/auth-safety.test.ts tests/firestore-paths.test.mjs tests/unit",
    "test:integration:local": "vitest run tests/browser-storage.test.ts tests/integration",
    "test:integration": "npm run test:integration:local && npm run test:rules",
    "test:rules": "npx --yes firebase-tools@15.24.0 emulators:exec --only firestore \"vitest run tests/firestore-rules.emulator.test.ts\" --project recepten-rules-test",
    "verify:backup": "node scripts/verify-backup-freshness.mjs",
    "deploy:safe": "npm test && npm run lint && npm run build && npm run verify:backup && npx --yes firebase-tools@15.24.0 deploy --only apphosting,firestore:rules --project recepten-app-87beb",
    "deploy": "npx --yes firebase-tools@15.24.0 deploy --only apphosting --project recepten-app-87beb"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "10.2.9",
    "date-fns": "^4.1.0",
    "firebase": "^12.16.0",
    "next": "16.2.11",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "next": {
      "postcss": "8.5.10",
      "sharp": "0.35.0"
    }
  }
}
